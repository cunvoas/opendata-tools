<?xml version="1.0" encoding="UTF-8"?>
<configuration>

	<!-- ISOCHRONE CONFIG LOG -->
	<!-- Explicit converter registration required for Logback 1.4+ (Spring Boot 
		3.x) -->
	<conversionRule conversionWord="clr"
		class="org.springframework.boot.logging.logback.ColorConverter" />
	<conversionRule conversionWord="wEx"
		class="org.springframework.boot.logging.logback.ExtendedWhitespaceThrowableProxyConverter" />

	<!-- Include Spring Boot defaults: registers %clr, %wEx converters, base 
		appenders, etc. -->
	<include
		resource="org/springframework/boot/logging/logback/defaults.xml" />
	<include resource="logback-properties.xml" />

	<!-- ============================= -->
	<!-- Variables communes -->
	<!-- ============================= -->
	<springProperty scope="context" name="appName"
		source="spring.application.name" defaultValue="isochrone" />
	<springProperty scope="context" name="logPath"
		source="logging.file.path" defaultValue="/var/log" />

	<property name="LOG_PATTERN_CONSOLE"
		value="%clr(%d{HH:mm:ss.SSS}){faint} %clr(%5p) %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n%wEx" />

	<property name="LOG_PATTERN_FILE"
		value="%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%t] %-40.40logger{39} : %m%n" />

	<!-- ============================= -->
	<!-- PROFIL DEV  Console colorée   -->
	<!-- ============================= -->
	<springProfile name="dev">

		<appender name="CONSOLE"
			class="ch.qos.logback.core.ConsoleAppender">
			<encoder
				class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
				<pattern>${LOG_PATTERN_CONSOLE}</pattern>
			</encoder>
		</appender>

		<!-- Spring Framework : INFO pour éviter le bruit -->
		<logger name="org.springframework" level="INFO" additivity="false">
			<appender-ref ref="CONSOLE" />
		</logger>

		<!-- Hibernate / SQL -->
		<logger name="org.hibernate.SQL" level="ERROR" additivity="false">
			<appender-ref ref="CONSOLE" />
		</logger>
		<logger name="org.hibernate.orm.jdbc.bind" level="ERROR" additivity="false">
			<appender-ref ref="CONSOLE" />
		</logger>

		<root level="WARN">
			<appender-ref ref="CONSOLE" />
		</root>

	</springProfile>

	<!-- ============================= -->
	<!-- PROFIL PROD -->
	<!-- Fichier roulant, niveau INFO -->
	<!-- ============================= -->
	<springProfile name="prod,pi,pi_nuc">

		<!-- Console minimaliste (stdout pour les agrégateurs de logs) -->
		<appender name="CONSOLE"
			class="ch.qos.logback.core.ConsoleAppender">
			<encoder
				class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
				<pattern>${LOG_PATTERN_FILE}</pattern>
			</encoder>
		</appender>

		<!-- Fichier roulant quotidien avec rétention 30 jours / 500 MB max -->
		<!-- Appender dédié pour batch-activity.log -->
		<appender name="BATCH_ACTIVITY_FILE"
			class="ch.qos.logback.core.rolling.RollingFileAppender">
			<file>${logPath}/activity-batch.log</file>
			<rollingPolicy
				class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
				<fileNamePattern>${logPath}/activity-batch.%d{yyyy-MM-dd}.%i.log.gz
				</fileNamePattern>
				<maxFileSize>100MB</maxFileSize>
				<maxHistory>30</maxHistory>
				<totalSizeCap>500MB</totalSizeCap>
			</rollingPolicy>
			<encoder
				class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
				<pattern>${LOG_PATTERN_FILE}</pattern>
			</encoder>
		</appender>

		<!-- ============================= -->
		<!-- LOG MONITORING DÉDIÉ -->
		<!-- (prometheus & awake HEAD) -->
		<!-- ============================= -->
		<appender name="MONITOR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
			<file>${logPath}/activity-monitoring.log</file>
			<rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
				<fileNamePattern>${logPath}/activity-monitoring.%d{yyyy-MM-dd}.%i.log.gz
				</fileNamePattern>
				<maxFileSize>100MB</maxFileSize>
				<maxHistory>30</maxHistory>
				<totalSizeCap>500MB</totalSizeCap>
			</rollingPolicy>
			<encoder
				class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
				<pattern>${LOG_PATTERN_FILE}</pattern>
			</encoder>
		</appender>

		<appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
			<file>${logPath}/${appName}.log</file>
			<rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
				<fileNamePattern>${logPath}/${appName}.%d{yyyy-MM-dd}.%i.log.gz
				</fileNamePattern>
				<maxFileSize>100MB</maxFileSize>
				<maxHistory>30</maxHistory>
				<totalSizeCap>500MB</totalSizeCap>
			</rollingPolicy>
			<encoder
				class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
				<pattern>${LOG_PATTERN_FILE}</pattern>
			</encoder>
		</appender>

		<root level="ERROR">
			<appender-ref ref="CONSOLE" />
			<appender-ref ref="FILE" />
		</root>

		<!-- Spring Framework -->
		<logger name="org.springframework" level="ERROR"
			additivity="false">
			<appender-ref ref="CONSOLE" />
			<appender-ref ref="FILE" />
		</logger>

		<!-- Logger dédié pour le filter BatchJobs -->
		<logger name="com.github.cunvoas.geoserviceisochrone.service.compute.BatchJobService"
			level="INFO" additivity="false">
			<appender-ref ref="BATCH_ACTIVITY_FILE" />
		</logger>

		<!-- Logger dédié pour le filter Prometheus (tous accès prometheus) -->
		<logger name="com.github.cunvoas.geoserviceisochrone.monitor.PrometheusFilter"
			level="INFO" additivity="false">
			<appender-ref ref="MONITOR_FILE" />
		</logger>
		<!-- Logger dédié pour HEAD /awake (RootController) -->
		<logger name="com.github.cunvoas.geoserviceisochrone.controller.RootController"
			level="INFO" additivity="false">
			<appender-ref ref="MONITOR_FILE" />
		</logger>

	</springProfile>

	<!-- ============================= -->
	<!-- Fallback (aucun profil actif) -->
	<!-- ============================= -->
	<springProfile name="!dev &amp; !prod">

		<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
			<encoder
				class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
				<pattern>${LOG_PATTERN_CONSOLE}</pattern>
			</encoder>
		</appender>

		<root level="INFO">
			<appender-ref ref="CONSOLE" />
		</root>

	</springProfile>

  <!-- UTILISé DANS UN FUTUR PROCHE -->
	<springProfile name="loki">
		<appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
			<http>
				<url>http://loki:3100/loki/api/v1/push</url>
			</http>

			<format>
				<label>
					<pattern>application=${appName},host=${HOSTNAME},level=%level
					</pattern>
				</label>
				<sortByTime>true</sortByTime>
			</format>
		</appender>
	</springProfile>


	<logger name="com.zaxxer.hikari.HikariConfig" level="INFO" />
	<logger name="com.zaxxer.hikari" level="ERROR" />


</configuration>
